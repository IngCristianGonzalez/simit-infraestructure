# GitHub Secrets para Backend
EC2_HOST=your-ec2-public-ip
EC2_USER=ubuntu
EC2_SSH_KEY=your-private-key-pem-content
ECR_REGISTRY=ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com
AWS_REGION=us-east-1

# GitHub Secrets para Frontend
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name
CLOUDFRONT_DISTRIBUTION_ID=your-distribution-id
FRONTEND_DOMAIN=www.yourdomain.com
FRONTEND_REPO=your-org/proyecto-simit-frontend
API_URL=https://api.yourdomain.com/api

# Supabase (van en .env.production de la EC2, NO en GitHub Secrets)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
